flutter_app/pubspec.lock

# Go build artifacts
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test caches and coverage
*.test
*.out
coverage/
coverage.txt

# Local config variants
config.local.yaml
config.*.local.yaml

# Planning and documentation (not needed in container)
.planning/
docs/
*.md
!README.md

# Docker files (prevent recursion)
docker-compose*.yml
.dockerignore
Dockerfile*

# CI/CD files
.github/
.gitlab-ci.yml
